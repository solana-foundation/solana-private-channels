# Plain-text secrets template. Copy to `secrets.yml` and fill in real values:
#   cp secrets.yml.example secrets.yml
# `secrets.yml` is gitignored — DO NOT COMMIT it.
# See README "Future improvements" for the SOPS+age upgrade path.
#
# Required: postgres_password, postgres_replication_password, jwt_secret,
#           grafana_admin_password, ghcr_user, ghcr_token.
# Optional: yellowstone_token (devnet/mainnet only), notify_webhook.

# Postgres super-user password. Used by postgres-primary and any service that
# connects as `private_channel`. Generate fresh: openssl rand -hex 16
postgres_password: ""

# Streaming-replication password used by postgres-replica.
# Read by init-primary.sql via the POSTGRES_REPLICATION_PASSWORD env var, so
# changing it here is sufficient — no other file needs to match.
# Generate fresh: openssl rand -hex 16
postgres_replication_password: ""

# Gateway JWT signing secret. 32+ random bytes.
# Only used when the auth service is enabled (gateway_enforce_jwt=true in vars/<env>.yml).
# Safe to leave at any non-empty value when the auth service is off.
# Generate fresh: openssl rand -hex 32
jwt_secret: ""

# Grafana admin password. URL: http://<host>:<monitoring_grafana_port>, user: admin.
# Forced password change on first login; rotate by editing here + redeploying.
grafana_admin_password: ""

# GHCR credentials. Required — the deploy pulls images from GHCR.
#   ghcr_user  = your GitHub username (or an org bot account).
#   ghcr_token = GitHub PAT with `read:packages` (add `write:packages` if CI also pushes).
# Create the PAT: https://github.com/settings/tokens/new?scopes=read:packages
# GHCR overview: https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-container-registry
ghcr_user: ""
ghcr_token: ""

# Yellowstone gRPC auth token (e.g. Helius `x-token`).
# Required when network=devnet/mainnet (paid providers all gate gRPC behind a token).
# Leave empty on localnet — the bundled validator's Yellowstone needs no auth.
yellowstone_token: ""

# notify_webhook — single endpoint for deploy-time and runtime alerts.
#   Deploy-time : site.yml POSTs the report-phase summary here when non-empty.
#   Runtime     : rendered into the stack's .env as ALERT_WEBHOOK_URL.
#                 Consumed by grafana (alert routing) and the indexer/operator services
#                 (reconciliation mismatches). Best-effort fire-and-forget POST today —
#                 no retry, no rate-limit, no dedup. See README "Future improvements".
# Benefit: one URL to change to redirect all alerts (Slack/Discord/Opsgenie webhooks).
# Leave empty to skip the deploy POST; runtime services fall back to a no-op URL.
notify_webhook: ""
