# Rendered by Ansible — do not edit by hand. Source: private-channel-deploy/templates/env.j2
# Consumed by docker-compose via --env-file. Mirrors keys from .env.example.

# --- Image tagging ---
PRIVATE_CHANNEL_VERSION={{ image_tag }}

# --- RPC + program IDs ---
LOCAL_VALIDATOR_RPC_URL={{ 'http://validator:8899' if network == 'localnet' else rpc_url }}
DEVNET_RPC_URL={{ rpc_url }}

# --- Yellowstone gRPC (indexer-solana real-time stream) ---
# localnet ignores these (compose hardcodes http://validator:10000); devnet/mainnet uses both.
DEVNET_YELLOWSTONE_ENDPOINT={{ yellowstone_endpoint | default('') }}
INDEXER_YELLOWSTONE_TOKEN={{ yellowstone_token | default('') }}
ESCROW_PROGRAM_ID={{ escrow_program_id | default('GokvZqD2yP696rzNBNbQvcZ4VsLW7jNvFXU1kW9m7k83') }}
WITHDRAW_PROGRAM_ID={{ withdraw_program_id | default('J231K9UEpS4y4KAPwGc4gsMNCjKFRMYcQBcjVW7vBhVi') }}
# Fallback: a syntactically-valid Pubkey (the system program's all-1s) so the
# indexer's `Pubkey::from_str` parses cleanly on first boot. Whoever runs
# `create_instance` post-deploy overwrites this with the real PDA and
# restarts the indexer/operator. Leaving this empty would also work (toml
# fallback kicks in) but compose's variable interpolation rejects unset vars
# by default.
ESCROW_INSTANCE_ID={{ escrow_instance_id | default('11111111111111111111111111111111') }}
# Bundled localnet validator boot mode. Explicit, not hardcoded: `validator_reset`
# (vars/common.yml, default true) → `--reset` boots from genesis every redeploy
# (the indexer reconciliation rationale in deploy.yml depends on this); set false
# to preserve the validator ledger across redeploys — the deploy analogue of
# `make docker-up-persist`. Only safe when Postgres is NOT wiped in lockstep.
VALIDATOR_RESET_FLAG={{ '--reset' if (validator_reset | default(true) | bool) else '' }}

# --- Postgres (passwords from SOPS) ---
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_REPLICATION_USER={{ postgres_replication_user }}
POSTGRES_REPLICATION_PASSWORD={{ postgres_replication_password }}
POSTGRES_INDEXER_DB={{ postgres_indexer_db }}

# --- Solana Private Channels node ---
PRIVATE_CHANNEL_WRITE_PORT={{ write_port }}
PRIVATE_CHANNEL_READ_PORT={{ read_port }}
PRIVATE_CHANNEL_SIGVERIFY_QUEUE_SIZE=10000000
PRIVATE_CHANNEL_SIGVERIFY_WORKERS=32
PRIVATE_CHANNEL_WRITE_MAX_CONNECTIONS=1000000
PRIVATE_CHANNEL_READ_MAX_CONNECTIONS=100000
PRIVATE_CHANNEL_PG_MAX_CONNECTIONS=32
PRIVATE_CHANNEL_MAX_TX_PER_BATCH=64
PRIVATE_CHANNEL_BATCH_DEADLINE_MS=10
PRIVATE_CHANNEL_BATCH_CHANNEL_CAPACITY=16
PRIVATE_CHANNEL_MAX_SVM_WORKERS=8
# Admin pubkey + private key. In single-host self-test mode these come from
# the on-disk keypair at {{ admin_keypair_path | default('keypairs/admin.json') }}.
# The pipeline phase computes them and writes them back into the rendered .env
# before bringing up the operator services. Until then the placeholders below
# satisfy compose variable interpolation; the operators don't actually start
# making transactions until the pipeline phase runs.
PRIVATE_CHANNEL_ADMIN_KEYS={{ private_channel_admin_keys | default(admin_pubkey | default('admin_pubkey')) }}
ADMIN_PRIVATE_KEY={{ admin_private_key | default('placeholder_b58') }}

# Escrow instance PDA. Created on-the-fly by the pipeline phase and rewritten
# into this file via `scripts/upsert-env.sh`-style replacement. The compose
# stack reads it as COMMON_ESCROW_INSTANCE_ID.
COMMON_ESCROW_INSTANCE_ID={{ escrow_instance_id_pda | default('11111111111111111111111111111111') }}

# --- Gateway ---
GATEWAY_PORT={{ gateway_port }}
GATEWAY_WRITE_URL=http://write-node:{{ write_port }}
GATEWAY_READ_URL=http://read-node:{{ read_port }}
GATEWAY_URL=http://gateway:{{ gateway_port }}

# --- Auth ---
# Setting JWT_SECRET non-empty makes the gateway enforce RBAC on
# ACCOUNT_GATED_METHODS (getAccountInfo, getSignaturesForAddress, …). The
# operator services don't carry a JWT — in production they live behind a
# private mesh and the gateway lets unauthenticated callers through. For
# the single-host self-test we expose the gateway on localhost and would
# otherwise lock the operators out of their own DB lookups, so we let env
# files set `gateway_enforce_jwt: false` to disable enforcement at deploy
# time. Production envs leave this true (the default in common.yml).
AUTH_PORT={{ auth_port }}
JWT_SECRET={{ jwt_secret if (gateway_enforce_jwt | default(true) | bool) else '' }}
CORS_ALLOWED_ORIGIN=https://{{ domain }}
AUTH_DATABASE_MAX_CONNECTIONS=10

# --- Streamer ---
STREAMER_PORT={{ streamer_port }}

# --- Grafana / alerting ---
GF_ADMIN_PASSWORD={{ grafana_admin_password }}
ALERT_WEBHOOK_URL={{ notify_webhook | default('http://localhost:9/no-op', true) }}
