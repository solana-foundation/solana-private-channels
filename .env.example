# Image tag for the private-channel-app containers (compose defaults to `latest`).
PRIVATE_CHANNEL_VERSION=latest

# Instance
ESCROW_INSTANCE_ID=instance_pubkey
# Escrow instance PDA the compose stack reads as COMMON_ESCROW_INSTANCE_ID.
# Created post-deploy via `create_instance`; compose interpolation needs it set,
# so default to the all-1s placeholder until the real PDA is written back.
COMMON_ESCROW_INSTANCE_ID=11111111111111111111111111111111
# Keep blank here: `make build-*` writes the live key to the gitignored `.env`.
ADMIN_PRIVATE_KEY=

# RPC endpoints
DEVNET_RPC_URL=solana_rpc_url
DEVNET_YELLOWSTONE_ENDPOINT=yellowstone_url
INDEXER_YELLOWSTONE_TOKEN=yellowstone_x_token
# Local validator RPC (Only if running docker locally)
LOCAL_VALIDATOR_RPC_URL=http://validator:8899
# Controls whether the local validator wipes its ledger on container start.
# Default `--reset` matches today's behavior (fresh ledger every `docker-up`).
# Set to blank to preserve /validator-data across restarts so on-chain state
# stays consistent with Postgres. After changing escrow/withdraw program code,
# run `make docker-clean` to force a fresh deploy. The `make docker-up-persist`
# target sets this for you.
VALIDATOR_RESET_FLAG=--reset

# PostgreSQL
POSTGRES_DB=private_channel
POSTGRES_USER=private_channel
# Required: set before startup. No default is shipped; services fail closed if blank.
POSTGRES_PASSWORD=
POSTGRES_REPLICATION_USER=replicator
# Required: set before startup. No default is shipped; services fail closed if blank.
POSTGRES_REPLICATION_PASSWORD=
POSTGRES_INDEXER_DB=indexer

# Solana Private Channels Node
PRIVATE_CHANNEL_WRITE_PORT=8900
PRIVATE_CHANNEL_READ_PORT=8901
PRIVATE_CHANNEL_SIGVERIFY_QUEUE_SIZE=10000000
PRIVATE_CHANNEL_SIGVERIFY_WORKERS=32
PRIVATE_CHANNEL_WRITE_MAX_CONNECTIONS=1000000
PRIVATE_CHANNEL_READ_MAX_CONNECTIONS=100000
# Postgres pool size per node (default 32, capped at 256).
PRIVATE_CHANNEL_PG_MAX_CONNECTIONS=32
PRIVATE_CHANNEL_MAX_TX_PER_BATCH=64
# Sequencer batch-flush deadline (ms).
PRIVATE_CHANNEL_BATCH_DEADLINE_MS=10
# Sequencer→executor batch channel capacity.
PRIVATE_CHANNEL_BATCH_CHANNEL_CAPACITY=16
# Executor parallel SVM worker cap.
PRIVATE_CHANNEL_MAX_SVM_WORKERS=8
# Space-separated admin pubkey(s). `make build-localnet` fills this (and
# ADMIN_PRIVATE_KEY) with a generated keypair; 
PRIVATE_CHANNEL_ADMIN_KEYS=admin_pubkey

# Gateway
GATEWAY_PORT=8899
GATEWAY_WRITE_URL=http://write-node:8900
GATEWAY_READ_URL=http://read-node:8901
GATEWAY_URL=http://gateway:8899

# Streamer
STREAMER_PORT=8902

# Auth Service
# Leave JWT_SECRET blank to disable RBAC enforcement on the gateway.
# WARNING: the value below is a placeholder. Any non-throwaway deployment
# (devnet, staging, prod) MUST replace it with a long random string —
# `openssl rand -hex 32` is fine. Leaving the placeholder is equivalent
# to publishing your signing key.
AUTH_PORT=8903
# Required only when enabling auth: set before startup. No default is shipped.
JWT_SECRET=
# Restrict the auth service CORS origin. Set to your frontend URL in production
# (e.g. https://app.solana-private-channel). Defaults to * if unset (local dev only).
CORS_ALLOWED_ORIGIN=https://your-frontend-url.com
# DB pool size for the auth service and the gateway's auth DB connection.
# Default is 10. Increase under high concurrency.
AUTH_DATABASE_MAX_CONNECTIONS=10

# Grafana
GF_ADMIN_PASSWORD=admin

# Alerting
ALERT_WEBHOOK_URL=https://your-webhook-url.com/endpoint

# Program IDs (under target/deploy/...-keypair.json)
# Only if running docker locally, as it deploys those programs
# to the local solana validator.
ESCROW_PROGRAM_ID=your_generated_escrow_program_id
WITHDRAW_PROGRAM_ID=your_generated_withdraw_program_id

