        {
          "datasource": { "type": "postgres", "uid": "postgres-indexer" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroup(created_at, $__interval) AS time,\n  COUNT(*) AS \"pending withdrawals\"\nFROM transactions\nWHERE transaction_type = 'withdrawal'\n  AND status = 'pending'\n  AND $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Pending Withdrawals Over Time",
      "type": "timeseries"
    },
