# Rendered by Ansible. Source: private-channel-deploy/templates/prometheus.yml.j2
#
# Scrape targets:
#   - blackbox HTTP probes for every Solana Private Channels service /health endpoint
#   - cAdvisor (containers), node_exporter (host), postgres_exporter (DBs)
#   - Solana Private Channels services that expose /metrics directly (write/read/gateway use
#     the metrics_port env vars in docker-compose.yml; we scrape the same
#     ports here when PRIVATE_CHANNEL_METRICS=true). Off by default; the rules
#     below tolerate missing targets gracefully.

global:
  scrape_interval: 10s
  scrape_timeout: 5s
  evaluation_interval: 15s

scrape_configs:

  # ── self ────────────────────────────────────────────────────────────────
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  # ── blackbox HTTP probes — the spec-recommended /health monitoring path.
  # Each target's `__param_target` is rewritten into the URL the blackbox
  # exporter actually probes; the exported metric series carry `instance`
  # = the friendly service name, which is what dashboards group by.
  - job_name: blackbox-http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - http://gateway:{{ gateway_port }}/health
          - http://write-node:{{ write_port }}/health
          - http://read-node:{{ read_port }}/health
          - http://indexer-solana:9100/health
          - http://indexer-private-channel:9100/health
          - http://operator-solana:9102/health
          - http://operator-private-channel:9103/health
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115

  # ── infra exporters ────────────────────────────────────────────────────
  - job_name: cadvisor
    static_configs:
      - targets: ['cadvisor:8080']

  - job_name: node-exporter
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: postgres-primary
    static_configs:
      - targets: ['postgres-exporter-primary:9187']
        labels:
          db: primary

  - job_name: postgres-indexer
    static_configs:
      - targets: ['postgres-exporter-indexer:9187']
        labels:
          db: indexer

  # ── Solana Private Channels indexer + operator /metrics — always-on. Each service binds
  # its Prometheus exporter to METRICS_PORT (see docker-compose.yml: indexers
  # default to 9100; operator-solana is 9102, operator-private-channel is 9103 so
  # bench-tps can scrape them on distinct host ports). The metrics already
  # carry a `program_type` label (escrow|withdraw) baked in by the app, so
  # dashboards group across solana/private-channel pairs naturally — no extra
  # relabeling needed here.
  - job_name: private-channel-indexer-solana
    static_configs:
      - targets: ['indexer-solana:9100']
        labels:
          stack: private-channel

  - job_name: private-channel-indexer-private-channel
    static_configs:
      - targets: ['indexer-private-channel:9100']
        labels:
          stack: private-channel

  - job_name: private-channel-operator-solana
    static_configs:
      - targets: ['operator-solana:9102']
        labels:
          stack: private-channel

  - job_name: private-channel-operator-private-channel
    static_configs:
      - targets: ['operator-private-channel:9103']
        labels:
          stack: private-channel

  # ── Solana Private Channels write/read node /metrics (only when the node is run
  # with --metrics / PRIVATE_CHANNEL_METRICS=true; otherwise these targets show
  # as down which is correct). Listed here so enabling node metrics requires no
  # Prometheus config change.
  - job_name: private-channel-services
    static_configs:
      - targets:
          - 'write-node:9090'
          - 'read-node:9090'
        labels:
          stack: private-channel

  # ── Gateway /metrics. The gateway always serves metrics (no flag) on
  # METRICS_PORT, default 9101. The RPC dashboard filters on job="gateway".
  - job_name: gateway
    static_configs:
      - targets:
          - 'gateway:9101'
        labels:
          stack: private-channel
